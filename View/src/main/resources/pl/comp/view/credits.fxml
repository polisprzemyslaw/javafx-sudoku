<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<VBox fx:id="creditsBox" alignment="CENTER" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="225.0" prefWidth="350.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="pl.comp.view.CreditsDisplayController">
   <children>
      <Text fx:id="textAuthors" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-translate-y: -20; -fx-text-alignment: center;" text="%credits.authors" textAlignment="CENTER">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <Text fx:id="textUniversity" strokeType="OUTSIDE" strokeWidth="0.0" style="-fx-translate-y: 10; -fx-text-alignment: center;" text="%credits.university" textAlignment="JUSTIFY">
         <font>
            <Font size="14.0" />
         </font>
      </Text>
      <Button fx:id="exitButton" alignment="CENTER" mnemonicParsing="false" onAction="#onExitButtonClick" style="-fx-translate-y: 30;" text="%credits.exit" textAlignment="CENTER" />
   </children>
</VBox>
